@{
  ViewData["Title"] = "Pedido Confirmado";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding-top:72px;">
  <div style="text-align:center;max-width:480px;padding:2rem;">
    <div style="width:80px;height:80px;background:rgba(74,124,89,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 2rem;font-size:2rem;color:#4A7C59;">
      <i class="ti ti-check"></i>
    </div>
    <span style="font-size:0.7rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);">Pedido confirmado</span>
    <h1 style="font-family:var(--font-serif);font-size:2.5rem;margin:1rem 0;color:var(--dark);">Obrigado pela sua compra!</h1>
    <p style="color:var(--dark-3);line-height:1.8;margin-bottom:0.5rem;">
      Seu pedido <strong>#@TempData["OrderId"]</strong> foi recebido com sucesso.
    </p>
    <p style="color:var(--dark-3);margin-bottom:2rem;">
      Total: <strong style="color:var(--gold);">R$ @TempData["OrderTotal"]</strong>
    </p>
    <p style="font-size:0.85rem;color:var(--mid);margin-bottom:2.5rem;">
      Você receberá um e-mail com os detalhes e o prazo de entrega. Nossa equipe cuidará da sua joia com todo carinho!
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn btn-outline">Voltar à Loja</a>
      <a href="/Product" class="btn btn-gold">Continuar Comprando</a>
    </div>
  </div>
</div>
