@model JewelryEcommerce.Domain.Order
@{
  ViewData["Title"] = $"Pedido #{Model.Id}";
  Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
  <div>
    <h1>Pedido #@Model.Id</h1>
    <div style="font-size:0.8rem;color:var(--mid);">@Model.CreatedAt.ToString("dd/MM/yyyy 'às' HH:mm")</div>
  </div>
  <a href="/Admin/Orders" class="btn btn-outline btn-sm"><i class="ti ti-arrow-left"></i> Voltar</a>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start;">
  <div>
    <!-- Items -->
    <div style="background:var(--white);padding:1.5rem;margin-bottom:1.5rem;">
      <h3 style="font-family:var(--font-serif);font-size:1.1rem;margin-bottom:1.5rem;">Itens do Pedido</h3>
      <table class="data-table">
        <thead><tr><th>Produto</th><th>Qtd</th><th>Preço</th><th>Subtotal</th></tr></thead>
        <tbody>
          @foreach (var i in Model.Items)
          {
            <tr>
              <td>@i.ProductName</td>
              <td>@i.Quantity</td>
              <td>R$ @i.Price.ToString("N0")</td>
              <td style="font-family:var(--font-serif);">R$ @((i.Price * i.Quantity).ToString("N0"))</td>
            </tr>
          }
        </tbody>
      </table>
      <div style="text-align:right;padding-top:1rem;border-top:1px solid var(--light);margin-top:0.5rem;">
        <span style="font-family:var(--font-serif);font-size:1.3rem;">Total: R$ @Model.Total.ToString("N0")</span>
      </div>
    </div>

    <!-- Customer -->
    <div style="background:var(--white);padding:1.5rem;">
      <h3 style="font-family:var(--font-serif);font-size:1.1rem;margin-bottom:1.5rem;">Dados do Cliente</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        @foreach (var row in new[]{
          ("Cliente", Model.CustomerName),
          ("E-mail", Model.CustomerEmail),
          ("Telefone", Model.CustomerPhone),
          ("Endereço", Model.ShippingAddress)
        })
        {
          <div>
            <div style="font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--mid);margin-bottom:0.25rem;">@row.Item1</div>
            <div style="font-size:0.9rem;">@row.Item2</div>
          </div>
        }
      </div>
    </div>
  </div>

  <!-- Status Panel -->
  <div style="background:var(--white);padding:1.5rem;position:sticky;top:1rem;">
    <h3 style="font-family:var(--font-serif);font-size:1.1rem;margin-bottom:1rem;">Status do Pedido</h3>
    <div style="margin-bottom:1.5rem;">
      <span class="status-badge status-@Model.Status" style="font-size:0.8rem;padding:0.4rem 0.9rem;">@Model.Status</span>
    </div>
    <form method="post" action="/Admin/UpdateOrderStatus">
      <input type="hidden" name="id" value="@Model.Id" />
      <div class="form-group">
        <label class="form-label">Alterar Status</label>
        <select name="status" class="form-control">
          @foreach (var s in Enum.GetValues<JewelryEcommerce.Domain.OrderStatus>())
{
    <option value="@s" selected="@(Model.Status == s ? "selected" : null)">@s</option>
}
        </select>
      </div>
      <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;">
        <i class="ti ti-check"></i> Atualizar
      </button>
    </form>

    <div style="border-top:1px solid var(--light);margin-top:1.5rem;padding-top:1.5rem;">
      <div style="font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--mid);margin-bottom:0.5rem;">Timeline</div>
      @{
        var statuses = Enum.GetValues<JewelryEcommerce.Domain.OrderStatus>().ToList();
        var currentIdx = statuses.IndexOf(Model.Status);
      }
      @foreach (var s in statuses)
      {
        var idx = statuses.IndexOf(s);
        var done = idx <= currentIdx && Model.Status != JewelryEcommerce.Domain.OrderStatus.Cancelled;
        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.4rem 0;">
          <div style="width:8px;height:8px;border-radius:50%;background:@(done?"var(--gold)":"var(--light)");flex-shrink:0;"></div>
          <span style="font-size:0.8rem;color:@(done?"var(--dark)":"var(--mid)");">@s</span>
        </div>
      }
    </div>
  </div>
</div>
