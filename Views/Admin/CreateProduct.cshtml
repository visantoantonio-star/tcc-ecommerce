@model JewelryEcommerce.Domain.Product
@{
  ViewData["Title"] = "Novo Produto";
  Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
  <h1>Novo Produto</h1>
  <a href="/Admin/Products" class="btn btn-outline btn-sm"><i class="ti ti-arrow-left"></i> Voltar</a>
</div>

<div style="max-width:720px;background:var(--white);padding:2rem;">
  <form method="post" action="/Admin/CreateProduct" enctype="multipart/form-data">
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Nome do Produto *</label>
        <input type="text" name="Name" class="form-control" required />
      </div>
      <div class="form-group">
        <label class="form-label">Categoria *</label>
        <select name="Category" class="form-control">
          @foreach (var c in new[]{"Anéis","Colares","Brincos","Pulseiras","Pingentes","Outros"})
          { <option>@c</option> }
        </select>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Descrição</label>
      <textarea name="Description" class="form-control" rows="4"></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Material</label>
      <input type="text" name="Material" class="form-control" placeholder="Ex: Ouro 18k + Diamante" />
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Preço (R$) *</label>
        <input type="number" name="Price" class="form-control" step="0.01" min="0" required />
      </div>
      <div class="form-group">
        <label class="form-label">Preço Original (opcional)</label>
        <input type="number" name="OriginalPrice" class="form-control" step="0.01" min="0" />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Estoque *</label>
        <input type="number" name="Stock" class="form-control" min="0" required value="0" />
      </div>
      <div class="form-group">
        <label class="form-label">Avaliação (0–5)</label>
        <input type="number" name="Rating" class="form-control" step="0.1" min="0" max="5" value="4.5" />
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Imagem do Produto</label>
      <input type="file" name="ImageFile" class="form-control" accept="image/*" />
    </div>
    <div style="display:flex;gap:2rem;margin-bottom:1.5rem;">
      <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;">
        <input type="checkbox" name="IsFeatured" value="true" /> Produto em destaque
      </label>
      <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;">
        <input type="checkbox" name="IsNew" value="true" /> Marcar como Novo
      </label>
    </div>
    <div style="display:flex;gap:1rem;">
      <button type="submit" class="btn btn-gold"><i class="ti ti-check"></i> Criar Produto</button>
      <a href="/Admin/Products" class="btn btn-outline">Cancelar</a>
    </div>
  </form>
</div>
