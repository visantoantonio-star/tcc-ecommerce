@model JewelryEcommerce.Controllers.AdminLoginModel
@{
  ViewData["Title"] = "Login Admin";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="min-height: calc(100vh - 160px); display:flex; align-items:center; justify-content:center; padding:3rem 1rem;">
  <div style="width:100%;max-width:420px;background:var(--white);padding:2.5rem;border-radius:1rem;box-shadow:0 25px 70px rgba(0,0,0,0.08);">
    <h1 style="margin-bottom:0.25rem;font-family:var(--font-serif);">Acesso Admin</h1>
    <p style="margin-bottom:1.75rem;color:var(--mid);">Entre com usuário e senha para acessar o painel administrativo.</p>

    <form asp-action="Login" method="post">
      <div class="form-group">
        <label class="form-label" for="Username">Usuário</label>
        <input asp-for="Username" class="form-control" id="Username" />
      </div>
      <div class="form-group">
        <label class="form-label" for="Password">Senha</label>
        <input asp-for="Password" type="password" class="form-control" id="Password" />
      </div>
      @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
      {
        <div class="alert alert-error" style="margin-bottom:1rem;">@Model.ErrorMessage</div>
      }
      <button type="submit" class="btn btn-gold" style="width:100%;">Entrar</button>
    </form>
  </div>
</div>
